# Spring Boot reads these as overrides for application.yml. Sensitive values
# should live here (never in committed yaml). Spring's relaxed binding maps
# QUIZPLATFORM_AZURE_AD_TENANT_ID → quizplatform.azure-ad.tenant-id, etc.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/quiz_platform
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
QUIZPLATFORM_AZURE_AD_TENANT_ID=REPLACE_WITH_TENANT_ID
QUIZPLATFORM_AZURE_AD_AUDIENCE=api://REPLACE_WITH_API_CLIENT_ID
QUIZPLATFORM_PLATFORM_PUBLIC_URL=http://localhost:5173
