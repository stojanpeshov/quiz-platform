# MSAL config — values come from your Entra ID app registrations.
VITE_AZURE_TENANT_ID=REPLACE_WITH_TENANT_ID
# IMPORTANT: this is the SPA app's client id, not the API app's.
VITE_AZURE_CLIENT_ID=REPLACE_WITH_SPA_CLIENT_ID
# The scope exposed by the API app registration (NOT the SPA one).
VITE_API_SCOPE=api://REPLACE_WITH_API_CLIENT_ID/access_as_user
# Where the Spring Boot backend listens. Vite proxies /api/** to this.
VITE_API_URL=http://localhost:8080
